// Hero Section Styles
// Dark mystical gradient background with subtle glows

$color-bg-primary: #0a0e1a;
$color-bg-secondary: #151b2b;
$color-text-primary: #f5f5f5;
$color-accent-gold: #d4af37;
$color-accent-crimson: #c91f1f;
$color-accent-royal: #4169e1;

$font-header: 'Cinzel', serif;
$font-body: 'Spectral', serif;

// ========== HERO SECTION ==========
.hero {
  position: relative;
  width: 100%;
  min-height: 60vh;
  margin-left: 280px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 4rem 2rem;

  @media (max-width: 768px) {
    margin-left: 0;
    min-height: 50vh;
    padding: 2rem 1.5rem;
  }
}

// ========== BACKGROUND WITH GLOWS ==========
.hero-background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    135deg,
    $color-bg-primary 0%,
    #0f1422 25%,
    #1a0f2e 50%,
    $color-bg-secondary 75%,
    $color-bg-primary 100%
  );
  z-index: 0;
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
  filter: blur(80px);
  mix-blend-mode: screen;

  &-1 {
    width: 600px;
    height: 600px;
    background: $color-accent-royal;
    top: -200px;
    left: -200px;
    animation: float 20s ease-in-out infinite;
  }

  &-2 {
    width: 500px;
    height: 500px;
    background: $color-accent-gold;
    bottom: -150px;
    right: -150px;
    animation: float 25s ease-in-out infinite 5s reverse;
  }

  &-3 {
    width: 400px;
    height: 400px;
    background: $color-accent-crimson;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: float 30s ease-in-out infinite 10s;
  }
}

@keyframes float {
  0%, 100% {
    transform: translate(0, 0);
  }
  33% {
    transform: translate(30px, -30px);
  }
  66% {
    transform: translate(-20px, 20px);
  }
}

// ========== HERO CONTENT ==========
.hero-content {
  position: relative;
  z-index: 10;
  text-align: center;
  max-width: 800px;
  margin: 0 auto;
  animation: fadeInDown 1s ease 0.3s both;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

// ========== HERO TITLE ==========
.hero-title {
  font-family: $font-header;
  font-size: 4rem;
  font-weight: 600;
  color: $color-accent-gold;
  margin-bottom: 1rem;
  text-shadow: 
    0 4px 20px rgba($color-accent-gold, 0.3),
    0 0 40px rgba($color-accent-royal, 0.15);
  letter-spacing: 3px;
  line-height: 1.1;

  @media (max-width: 768px) {
    font-size: 2.5rem;
    letter-spacing: 2px;
  }

  @media (max-width: 480px) {
    font-size: 2rem;
    letter-spacing: 1px;
  }
}

// ========== HERO SUBTITLE ==========
.hero-subtitle {
  font-family: $font-body;
  font-size: 1.4rem;
  color: $color-text-primary;
  margin-bottom: 2rem;
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  letter-spacing: 0.5px;
  line-height: 1.6;

  @media (max-width: 768px) {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 480px) {
    font-size: 1rem;
  }
}

// ========== HERO DIVIDER ==========
.hero-divider {
  width: 100px;
  height: 2px;
  background: linear-gradient(
    90deg,
    transparent,
    $color-accent-gold,
    transparent
  );
  margin: 2rem auto;
  opacity: 0.6;
}

// ========== HERO META ==========
.hero-meta {
  font-family: $font-body;
  font-size: 0.95rem;
  color: rgba($color-text-primary, 0.8);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin: 0;

  @media (max-width: 768px) {
    font-size: 0.85rem;
  }
}
