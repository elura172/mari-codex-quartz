/* Mari Codex Dark Mystical Theme */
/* Override Quartz CSS variables */

:root {
  /* Dark Mystical Color Palette */
  --light: #0a0e1a;
  --lightgray: #151b2b;
  --gray: #a0a0a0;
  --darkgray: #f5f5f5;
  --dark: #f5f5f5;
  
  /* Accents */
  --primary: #d4af37;      /* Gold */
  --secondary: #4169e1;    /* Royal Blue */
  --tertiary: #2d5a3d;     /* Forest Green */
  
  /* Additional accents */
  --crimson: #c91f1f;
  --clay: #d4a574;
  
  /* Typography */
  --headerFont: 'Cinzel', serif;
  --bodyFont: 'Spectral', serif;
  --codeFont: 'Space Mono', monospace;
  
  /* Textual Content */
  --textHighlight: rgba(212, 175, 55, 0.1);
  --calloutHighlight: rgba(65, 105, 225, 0.1);
}

body {
  background: linear-gradient(135deg, #0a0e1a 0%, #0f1422 50%, #151b2b 100%);
  color: #f5f5f5;
  font-family: 'Spectral', serif;
}

h1, h2, h3, h4, h5, h6 {
  font-family: 'Cinzel', serif;
  color: #d4af37;
}

a {
  color: #d4af37;
  border-bottom: 1px solid rgba(212, 175, 55, 0.4);
  transition: all 0.3s ease;
}

a:hover {
  color: #d4a574;
  border-bottom-color: #d4a574;
  text-shadow: 0 0 8px rgba(212, 175, 55, 0.3);
}

/* Code styling */
code {
  background: rgba(65, 105, 225, 0.1);
  color: #d4a574;
  font-family: 'Space Mono', monospace;
}

pre {
  background: rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(212, 175, 55, 0.2);
  border-radius: 6px;
}

/* Blockquotes */
blockquote {
  border-left: 4px solid #d4af37;
  background: rgba(212, 175, 55, 0.05);
  color: #a0a0a0;
}

/* Tables */
table thead {
  background: rgba(65, 105, 225, 0.1);
}

table th {
  color: #d4af37;
  border-bottom: 2px solid rgba(212, 175, 55, 0.3);
}

table tr:hover {
  background: rgba(212, 175, 55, 0.05);
}
